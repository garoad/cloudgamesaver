{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CloudGameSaver",
  "version": "0.1.4",
  "identifier": "com.garoad.cloudgamesaver",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CloudGameSaver",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app", "appimage"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYzQjQxMzU3Qjc5MjAxNDMKUldSREFaSzNWeE8wWTBYaHNDMXBFTzZ1NVREWDd6TWxsRHg1aUNqaytPSUl0UEtOTmhvemE2RjgK",
      "endpoints": [
        "https://github.com/garoad/cloudgamesaver/releases/latest/download/latest.json"
      ]
    }
  }
}
